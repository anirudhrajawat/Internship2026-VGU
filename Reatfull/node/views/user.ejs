<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Users</title>
</head>
<body>
    <h1>All Users</h1>
    <ul>
        <% users.forEach(user => { %>
            <li>
                <strong><%= user.username %></strong> - 
                Age: <%= user.age %>, City: <%= user.city %>
            </li>
        <% }) %>
    </ul>
</body>
</html>