<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Product</title>
</head>
<body>
    <h1>Edit Product</h1>
    <form action="/products/<%= product.id %>?_method=PUT" method="POST">
        <label>Title: <input type="text" name="title" value="<%= product.title %>" required></label><br>
        <label>Price: <input type="number" name="price" value="<%= product.price %>" required></label><br>
        <label>Description: <textarea name="desc" required><%= product.desc %></textarea></label><br>
        <button type="submit">Update</button>
    </form>
    <a href="/products/<%= product.id %>">Cancel</a>
</body>
</html>
